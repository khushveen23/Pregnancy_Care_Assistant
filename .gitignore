# Virtual environment
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# FAISS indexes (large binary files — rebuild with ingest.py)
dutta_index/
oxford_index/
williams_index/

# PDF textbooks (large files — not needed in repo)
*.pdf

# Whisper model cache (downloaded automatically)
*.pt

# Temp audio files
*.wav
*.mp3

# OS files
.DS_Store
Thumbs.db

# Environment variables (keep your API key safe!)
.env
*.env

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Logs
*.log
